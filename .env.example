# Concord wallet "Send" backend — environment variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env (it is gitignored).

# Your Circle developer-platform API key
CIRCLE_API_KEY=your_real_api_key_here
# Your Circle entity secret
CIRCLE_ENTITY_SECRET=your_real_entity_secret_here
# Your Circle developer-controlled wallet id (the agent wallet 0x76bc...)
CIRCLE_WALLET_ID=your_wallet_id_here
# Public tunnel endpoint for the Circle Event Monitor webhook, e.g.
# https://<tunnel>.trycloudflare.com  (from `cloudflared tunnel --url http://localhost:3000`)
WEBHOOK_URL=
